# ================================================
# SARTE GLOBAL - Next.js .gitignore
# ================================================

# ── Next.js Build Outputs ──────────────────────
.next/
out/
build/
dist/

# ── Dependencies ───────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm/

# ── Environment Files (NEVER COMMIT THESE) ────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ── Logs ───────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.next-panic-*.log

# ── Testing / Coverage ─────────────────────────
coverage/
.nyc_output/
.coverage/
*.lcov

# ── IDE / Editor ───────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.project
.classpath
*.sublime-project
*.sublime-workspace

# ── OS Generated ───────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ── TypeScript / ESLint Cache ─────────────────
*.tsbuildinfo
.eslintcache
.stylelintcache

# ── Turbopack / Bundler Cache ──────────────────
# Note: .next already covers .next/cache, but explicit:
.turbo/
.cache/
.parcel-cache/
.webpack/

# ── Temporary Files ────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.pid
*.seed
*.pid.lock
*.orig
*.rej

# ── Package Manager Specific ───────────────────
# Note: package-lock.json, yarn.lock, and pnpm-lock.yaml
# SHOULD be committed for reproducible builds - they are NOT ignored

# ── Vercel / Deployment ────────────────────────
.vercel/
.vercel_build_output/

# ── Storybook ──────────────────────────────────
storybook-static/

# ── Local Certificates / SSL ───────────────────
*.pem
*.key
*.crt
*.cert

# ── Debugging ──────────────────────────────────
core.*
*.core
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database / Local Storage ───────────────────
*.db
*.sqlite
*.sqlite3
.prisma/client/

# ── Local Netlify ──────────────────────────────
.netlify/

# ── Sentry / Monitoring ────────────────────────
.sentryclirc

# ── Python / Scripting ──────────────────────────
__pycache__/
*.pyc

# ── Scratch / Temporary Files ──────────────────
input.txt

# ── AI Assistant Config ─────────────────────────
.claude/
.gemini/

# ── PocketBase Local Data ───────────────────────
pb_data/
pb_migrations/
pocketbase.exe
pocketbase
